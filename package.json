{
  "name": "app-microservicos",
  "private": true,
  "version": "0.0.1",
  "description": "Projeto de aprendizado: microsserviços, mensageria e micro frontends",
  "workspaces": [
    "services/*",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "orders:dev": "npm run dev --workspace=orders-service",
    "notifications:dev": "npm run dev --workspace=notifications-service",
    "dev": "npm-run-all --parallel orders:dev notifications:dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
